# ===== Provider 1 (mac dinh) — dung cho agent chon "default" =====
# Mac dinh: Groq (free, nhanh). Dang ky key tai https://console.groq.com
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=dan_api_key_cua_ban_vao_day
LLM_MODEL=llama-3.3-70b-versatile
LLM_LABEL=Groq

# ===== Provider 2 (tuy chon) — dung cho agent chon "alt" =====
# Cau hinh neu muon moi agent dung mot "bo nao" khac nhau.
# Vi du Google Gemini (free): https://aistudio.google.com/app/apikey
# LLM2_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM2_API_KEY=...
# LLM2_MODEL=gemini-2.0-flash
# LLM2_LABEL=Gemini

# ----- Vi du dung OpenRouter cho provider 1 -----
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=...
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
# LLM_LABEL=OpenRouter

# ===== Tra cuu web (tuy chon) =====
# Bat tinh nang "Cho phep tra cuu" tren UI se cho agent tim dan chung that.
# Khong bat buoc: neu bo trong se tu dung DuckDuckGo (mien phi, khong can key).
# Muon ket qua tot hon co the dung Tavily (free tier): https://tavily.com
# TAVILY_API_KEY=...
